# https://platform.openai.com/api-keys (или ключ OpenAI-совместимого прокси, напр. ProxyAPI)
OPENAI_API_KEY=

# Опционально: модель для агентов и инструмента study_assistant (по умолчанию gpt-4o-mini)
# OPENAI_MODEL_NAME=gpt-4o-mini

# OpenAI-совместимый API: базовый URL (без правки tools.py — см. README, раздел ProxyAPI)
# Пример ProxyAPI: https://proxyapi.ru/docs/openai-compatible-api
# OPENAI_API_BASE=https://openai.api.proxyapi.ru/v1
# Для LiteLLM+CrewAI при ProxyAPI см. README: префикс openai/ в имени модели или автоподстановка.
# OPENAI_MODEL_NAME=openai/openrouter/deepseek/deepseek-chat-v3.1
# LEARNING_SKIP_OPENAI_MODEL_PREFIX=true
# LEARNING_OPENAI_MODEL_OPENAI_TRANSPORT=true

# https://serper.dev — поиск Google через API (SerperDevTool)
SERPER_API_KEY=

# Неинтерактивный запуск (опционально)
# LEARNING_TOPIC=
# LEARNING_AUDIENCE=adult
# LEARNING_REGION=UNSPEC

# --- Лимиты и поведение (см. curriculum_builder/settings.py)
# TOPIC_MAX_LEN=500
# SLUG_MAX_LENGTH=60
# SERPER_N_RESULTS=8
# LEARNING_OUTPUT_PREFIX=learning_trajectory
# STUDY_ASSISTANT_MAX_TOKENS=900
# STUDY_ASSISTANT_TEMPERATURE=0.3
# STUDY_ASSISTANT_MAX_QUESTION_CHARS=8000
# CREW_VERBOSE=true
# CREW_MEMORY=false

# --- Отладка LLM (LiteLLM под капотом у CrewAI; см. README)
# LITELLM_LOG=DEBUG
# LEARNING_LITELLM_DEBUG=true
# LITELLM_LOG_RAW=true

# --- Тексты и промпты (см. curriculum_builder/prompts.py; многострочные — в кавычках)
# SAFETY_POLICY_SNIPPET="..."
# CLI_ARGPARSE_DESCRIPTION="..."
# CLI_HELP_TOPIC="..."
# CLI_HELP_AUDIENCE="..."
# CLI_HELP_REGION="..."
# CLI_PROMPT_TOPIC="Тема обучения: "
# CLI_ERROR_TOPIC_NONINTERACTIVE="..."
# CLI_ERROR_TOPIC_TOO_LONG="Тема длиннее {max_len} символов. Сократите формулировку."
# CLI_PROMPT_EMPTY_RETRY="..."
# CLI_AUDIENCE_INTRO="..."
# CLI_AUDIENCE_PROMPT_CHOICE="..."
# CLI_AUDIENCE_INVALID="..."
# CLI_REGION_INTRO="..."
# CLI_REGION_PROMPT="..."
# REGION_VALIDATION_ERROR="..."
# Подписи пунктов меню аудитории (JSON-объект с ключами child, teen, adult, mixed)
# CLI_AUDIENCE_LABELS_JSON={"child":"...","teen":"...","adult":"...","mixed":"..."}
# STUDY_ASSISTANT_SYSTEM_PROMPT="..."
# STUDY_ASSISTANT_TOOL_DESCRIPTION="..."
# STUDY_ASSISTANT_EMPTY_QUESTION="..."
# STUDY_ASSISTANT_MISSING_KEY="..."
# STUDY_ASSISTANT_IMPORT_ERROR="..."
# STUDY_ASSISTANT_EMPTY_REPLY="..."
# MARKDOWN_DISCLAIMER_BODY="..."
# MARKDOWN_METADATA_TEMPLATE="..."  # плейсхолдеры: {topic_esc}, {audience}, {region}, {utc}, {disclaimer_body}
# AGENT_RESEARCHER_ROLE="..."
# AGENT_RESEARCHER_GOAL="..."  # {topic}, {audience}, {region}
# AGENT_RESEARCHER_BACKSTORY_PREFIX="..."
# AGENT_ARCHITECT_ROLE="..."
# AGENT_ARCHITECT_GOAL="..."
# AGENT_ARCHITECT_BACKSTORY_PREFIX="..."  # {topic}, {audience}, {region}
# AGENT_EDITOR_ROLE="..."
# AGENT_EDITOR_GOAL="..."
# AGENT_EDITOR_BACKSTORY_PREFIX="..."
# TASK_RESEARCH_DESCRIPTION="..."
# TASK_RESEARCH_EXPECTED_OUTPUT="..."
# TASK_TRAJECTORY_DESCRIPTION="..."
# TASK_TRAJECTORY_EXPECTED_OUTPUT="..."
# TASK_MARKDOWN_DESCRIPTION="..."
# TASK_MARKDOWN_EXPECTED_OUTPUT="..."
# WARN_MISSING_OPENAI_KEY="..."
# WARN_MISSING_SERPER_KEY="..."
